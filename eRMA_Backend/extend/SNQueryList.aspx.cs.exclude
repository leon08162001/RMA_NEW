{
    OleDbConnection myCon = null;
    OleDbCommand myCmd = null;
    OleDbDataReader myDr = null;
    string ConStr = "";
    DataSet ds = null;
    
    //filter condition
    string sSDate = "";
    string sEDate = "";
    string sPartPN = "";
    string sPartSN = "";
    string sSubPartSN = "";
