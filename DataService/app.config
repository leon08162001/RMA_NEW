<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
    </configSections>
    <connectionStrings>
        <add name="DataService.My.MySettings.ConnectionString1" connectionString="Data Source=60.250.80.7:1521/eRMA;Persist Security Info=True;User ID=Cipherlab;Password=Cipherlab;Unicode=True" providerName="System.Data.OracleClient"/>
        <add name="DataService.My.MySettings.ConnectionString2" connectionString="Data Source=192.168.1.8:1521/eRMA;Persist Security Info=True;User ID=Cipherlab;Password=Cipherlab;Unicode=True" providerName="System.Data.OracleClient"/>
        <add name="DataService.My.MySettings.ConnectionString" connectionString="Data Source=192.168.7.20:1521/TOPPROD;Persist Security Info=True;User ID=rma;Unicode=True" providerName="System.Data.OracleClient"/>
        <add name="DataService.My.MySettings.ConnectionString3" connectionString="DATA SOURCE=TOPTEST;PASSWORD=1234rma;USER ID=RMA" providerName="Oracle.ManagedDataAccess.Client"/>
    </connectionStrings>
    <system.diagnostics>
        <sources>
            <!-- 這個區段定義 My.Application.Log 的記錄組態-->
            <source name="DefaultSource" switchName="DefaultSwitch">
                <listeners>
                    <add name="FileLog"/>
                    <!-- 取消註解下列區段，以寫入應用程式事件記錄檔-->
                    <!--<add name="EventLog"/>-->
                </listeners>
            </source>
        </sources>
        <switches>
            <add name="DefaultSwitch" value="Information"/>
        </switches>
        <sharedListeners>
            <add name="FileLog" type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL" initializeData="FileLogWriter"/>
            <!-- 取消註解下列區段，並將 APPLICATION_NAME 取代成您的應用程式名稱，以寫入至應用程式事件記錄檔-->
            <!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
        </sharedListeners>
    </system.diagnostics>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7"/></startup></configuration>
