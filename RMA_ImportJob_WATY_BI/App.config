<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<configSections>
	</configSections>
	<connectionStrings>
		<add name="DataService.My.MySettings.ConnectionString3" connectionString="DATA SOURCE=TOPTEST;PASSWORD=1234rma;USER ID=RMA"
            providerName="Oracle.ManagedDataAccess.Client" />
	</connectionStrings>
	<appSettings>
		<!--正式-->
		<!--<add key="dbConnection" value="SERVER=192.168.7.20:1521/topprod;UID=rma;PWD=4321rma"/>-->
		<!--測試-->
		<add key="dbConnection" value="SERVER=192.168.7.20:1521/toptest;UID=rma;PWD=1234rma"/>
		<add key="logPath" value="Logs\" />		
	</appSettings>
	<system.diagnostics>
		<sources>
			<!-- 這個區段定義 My.Application.Log 的記錄組態-->
			<source name="DefaultSource" switchName="DefaultSwitch">
				<listeners>
					<add name="FileLog"/>
					<!-- 取消註解下列區段，以寫入應用程式事件記錄檔-->
					<!--<add name="EventLog"/>-->
				</listeners>
			</source>
		</sources>
		<switches>
			<add name="DefaultSwitch" value="Information"/>
		</switches>
		<sharedListeners>
			<add name="FileLog" type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL" initializeData="FileLogWriter"/>
			<!-- 取消註解下列區段，並將 APPLICATION_NAME 取代成您的應用程式名稱，以寫入至應用程式事件記錄檔-->
			<!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
		</sharedListeners>
	</system.diagnostics>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7"/>
	</startup>
</configuration>
