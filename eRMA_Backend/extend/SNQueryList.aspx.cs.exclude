    protected void Page_Load(object sender, EventArgs e)
    {
        ConStr = "Provider=MSDAORA;Data Source=topprod;User ID=RMA;Password=4321RMA;";
        myCon = new OleDbConnection(ConStr);

        if (!this.IsPostBack)
        {
            CheckParameter();            

            if (Request.QueryString["sEDate"] != null)
                ExecuteQuery();
        }          
    }

    private void CheckParameter()
    {
        //get the condition if have
        if (Request.QueryString["sSDate"] != null)
        {
            sSDate = Request.QueryString["sSDate"].ToString();
            this.txt_sDate.Text = sSDate;
        }
        else
        {
            //日期預設前三個月
            this.txt_sDate.Text = DateTime.Now.AddMonths(-3).ToString("yyyy/MM/dd");
            sSDate = txt_sDate.Text;
        }

        if (Request.QueryString["sEDate"] != null)
        {
            sEDate = Request.QueryString["sEDate"].ToString();
            this.txt_eDate.Text = sEDate;
        }
        else
        {
            //日期預設前三個月
            this.txt_eDate.Text = DateTime.Now.AddMonths(-1).ToString("yyyy/MM/dd");
            sEDate = txt_eDate.Text;
        }


        if (Request.QueryString["sPartPN"] != null)
        {
            sPartPN = Request.QueryString["sPartPN"].ToString();
            this.txt_PartsPN.Text = sPartPN;
        }

        if (Request.QueryString["sPartSN"] != null)
        {
            sPartSN = Request.QueryString["sPartSN"].ToString();
            this.txt_PartsSN.Text = sPartSN;
        }

        if (Request.QueryString["sCustNO"] != null)
        {
            sCustNO = Request.QueryString["sCustNO"].ToString();
            this.txt_CustNo.Text = sCustNO;
        }

        if (Request.QueryString["sPONO"] != null)
        {
            sPONO = Request.QueryString["sPONO"].ToString();
            this.txt_POSN.Text = sPONO;
        }

        if (Request.QueryString["sSNNO"] != null)
        {
            sSNNO = Request.QueryString["sSNNO"].ToString();
            this.txt_ShippingSN.Text = sSNNO;
        }

        if (Request.QueryString["sPKNO"] != null)
        {
            sPKNO = Request.QueryString["sPKNO"].ToString();
            this.txt_PackingSN.Text = sPKNO;
        }
    }

    protected void ExecuteQuery()
    {
        myCon.Open();

        string sSQL = "";

        sSQL = "select export_ordernumber, export_m_sn, b.expar_m_sn, expar_m_itemno, export_partno, export_serialno, export_custno, export_customername, export_salesnumber, to_char(export_shipping_time,'yyyy/mm/dd') as export_shipping_time , to_char(export_warranty_date,'yyyy/mm/dd') as export_warranty_date,  substr(expar_poid,0,14) as expar_poid " +
                "from export a left join (select distinct expar_m_itemno, expar_m_sn, expar_poid from export_parts) b on a.export_serialno=b.expar_m_sn " +
                "where 1=1 ";

        //出貨時間過濾
        if (sSDate != "")
            sSQL = sSQL + " and export_shipping_time>=to_date('" + sSDate + "','yyyy/mm/dd') ";

        if (sEDate != "")
            sSQL = sSQL + " and export_shipping_time<=to_date('" + sEDate + "','yyyy/mm/dd') ";

        //產品/零件序號過濾
        if (sPartSN != "")
            sSQL = sSQL + "and (export_serialno like '%" + sPartSN.Trim() + "%' or export_m_sn like '%" + sPartSN.Trim() + "%')";

        //產品料號過濾
        if (sPartPN != "")
            sSQL = sSQL + " and (export_partno like '%" + sPartPN.Trim() + "%' or  expar_m_itemno like '%" + sPartPN.Trim() + "%') ";

        //客戶編號過濾
        if (sCustNO != "")
            sSQL = sSQL + " and export_custno like '%" + sCustNO.Trim() + "%' ";

        //訂單編號過濾
        if (sPONO != "")
            sSQL = sSQL + " and export_ordernumber like '%" + sPONO.Trim() + "%' ";

        //出通單編號過濾
        if (sSNNO != "")
            sSQL = sSQL + " and export_salesnumber like '%" + sSNNO.Trim() + "%' ";

        //工單編號過濾
        if (sPKNO != "")
            sSQL = sSQL + " and substr(expar_poid,0,14) like '%" + sPKNO.Trim() + "%' ";

        //成品序號過濾
        if (sPKNO != "")
            sSQL = sSQL + " and substr(expar_poid,0,14) like '%" + sPKNO.Trim() + "%' ";


        sSQL = sSQL + " order by export_m_sn ";

        //Response.Write(sSQL);

        myCmd = new OleDbCommand(sSQL, myCon);

        myDr = myCmd.ExecuteReader();
        
        ds = new DataSet();
        ds.Load(myDr, LoadOption.OverwriteChanges, "t1");


        this.GridView1.DataSource = ds.Tables["t1"].DefaultView;
        this.GridView1.DataBind();

        this.lbl_TotalAmount.Text = "共 " + ds.Tables["t1"].Rows.Count.ToString() + " 筆";

        //是否顯示筆數和Excel按鈕
        this.btnExcel.Visible = (ds.Tables["t1"].Rows.Count > 0);

        myCon.Close();

    }

