    protected void GridView1_PageIndexChanging(object sender, GridViewPageEventArgs e)
    {
        CheckParameter();

        ExecuteQuery();

        this.GridView1.PageIndex = e.NewPageIndex;

        this.GridView1.DataBind();
    }

    protected void btn_Reset_Click(object sender, EventArgs e)
    {
        Response.Redirect("SNQueryList.aspx");
    }


     /**//// <summary> 
     /// 傳入DataTable後，透過Response.Write將資料寫到client端，並指定為Excel格式 
     /// </summary> 
     /// <param name="pDataTable">資料來源</param> 
     public void ExportDataTableToExcel(GridView exportGrid) 
     {
         int tRowCount = exportGrid.Rows.Count;
         int tColumnCount = exportGrid.Columns.Count;
         
         Response.Expires = 0; 
         Response.Clear(); 
         Response.Buffer = true; 
         Response.Charset = "utf-8"; 
         Response.ContentEncoding = System.Text.Encoding.UTF8; 
         Response.ContentType = "application/vnd.ms-excel"; 
         Response.AddHeader("Content-Disposition", "attachment; filename=SNQueryList.xls"); 
         Response.Write("<meta http-equiv=Content-Type content=text/html;charset=utf-8>"); 
  
         Response.Write("<Table borderColor=black border=1>"); 
         Response.Write("\n <TR>"); 

         for (int i = 0; i < tColumnCount; i++) 
         {
             Response.Write("\n <TD  bgcolor=\"#507CD1\" style= \"font-size:12px;color:#ffffff\"  align=\"center\">");
             Response.Write(exportGrid.Columns[i].HeaderText); 
             Response.Write("\n </TD>"); 
         } 

         Response.Write("\n </TR>");


         for (int j = 0; j < tRowCount; j++)
         {
             Response.Write("\n <TR>");
             for (int k = 0; k < tColumnCount; k++)
             {
                 Response.Write("\n <TD align=\"center\" x:num>");

                 if (exportGrid.Rows[j].Cells[k].Controls[0].GetType().Name == "Label")
                 {
                     Response.Write(((Label)exportGrid.Rows[j].Cells[k].Controls[0]).Text);
                 }
                 else
                 {
                     Response.Write(((HyperLink)exportGrid.Rows[j].Cells[k].Controls[0]).Text);
                 }

                 Response.Write("\n </TD>");
             }
             Response.Write("\n </TR>");
         }
  
         Response.Write("</Table>"); 
  
         Response.End(); 
     }
    

    protected void btnExcel_Click(object sender, EventArgs e)
    {
        GridView1.AllowPaging = false;
        GridView1.DataBind();

        this.ExportDataTableToExcel(GridView1);

        GridView1.AllowPaging = true;
        GridView1.DataBind();
    }

